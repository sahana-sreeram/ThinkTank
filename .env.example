# Policy Think Tank — environment configuration.
# Copy to .env and adjust. The system runs LOCAL-ONLY by default; no secrets required.

# --- Mock mode -------------------------------------------------------------
# 1 = agents return fixture-backed mocks (no model needed). Default for the
# shared skeleton. Set to 0 once real agents + a local model are available.
POLICY_MOCK_MODE=1

# --- Local model (Ollama) --------------------------------------------------
# Local model via Ollama. `ollama pull qwen3:8b` (or set this to any tag you pulled).
POLICY_LOCAL_MODEL=qwen3:8b

# --- Optional frontier fallback (OFF by default) ---------------------------
# Only used when local structured output repeatedly fails validation or the
# Director must resolve materially conflicting conclusions.
POLICY_ENABLE_FALLBACK=0
POLICY_FRONTIER_MODEL=
# Provide the relevant API key ONLY if you enable fallback. Never commit it.
# ANTHROPIC_API_KEY=

# --- Evidence retrieval (P2) ----------------------------------------------
# Evidence retrieval is gated separately from agent reasoning. Set to 0 to turn
# real sources (connectors + Chroma cache) ON while keeping mock agents — the
# demo then shows real citations without the local LLM. Defaults to MOCK_MODE.
POLICY_MOCK_RETRIEVAL=1
# Hybrid retrieval: query the local Chroma cache first, then live-fetch from the
# external source connectors (sources/) when the cache is thin. Set to 0 to run
# cache-only / fully offline (e.g. a demo with no network).
POLICY_LIVE_FETCH=1
# Soft budget of evidence items pulled per live fetch (divided across connectors).
POLICY_EVIDENCE_BUDGET=18
# Per-request network timeout (seconds) for any single source.
POLICY_HTTP_TIMEOUT=12

# --- Source API keys (all OPTIONAL; connectors skip cleanly if unset) -------
# OpenAlex & Socrata (US DOT) need NO key. Semantic Scholar works keyless but
# rate-limits hard; a free key raises the limit.
# SEMANTIC_SCHOLAR_API_KEY=
# SOCRATA_APP_TOKEN=
# Census ACS requires a free key (api.census.gov/data/key_signup.html).
# CENSUS_API_KEY=
# MBTA works keyless at a low rate limit; a free key raises it (api-v3.mbta.com).
# MBTA_API_KEY=
# EPA AQS requires free email+key registration (aqs.epa.gov/data/api).
# EPA_AQS_EMAIL=
# EPA_AQS_KEY=
