# Policy Think Tank — environment configuration.
# Copy to .env and adjust. The system runs LOCAL-ONLY by default; no secrets required.

# --- Mock mode -------------------------------------------------------------
# 1 = agents return fixture-backed mocks (no model needed). Default for the
# shared skeleton. Set to 0 once real agents + a local model are available.
POLICY_MOCK_MODE=1

# --- Local model (Ollama) --------------------------------------------------
# Local model via Ollama. `ollama pull qwen3:8b` (or set this to any tag you pulled).
POLICY_LOCAL_MODEL=qwen3:8b

# --- Optional frontier fallback (OFF by default) ---------------------------
# Only used when local structured output repeatedly fails validation or the
# Director must resolve materially conflicting conclusions.
POLICY_ENABLE_FALLBACK=0
POLICY_FRONTIER_MODEL=
# Provide the relevant API key ONLY if you enable fallback. Never commit it.
# ANTHROPIC_API_KEY=
